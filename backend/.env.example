# Environment Configuration for Bens Trans

# Development Mode (set to 'development' for mock payments, 'production' for real M-Pesa)
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=bensdb

# M-Pesa Configuration (Production - get these from Safaricom)
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=your_business_shortcode
MPESA_PASSKEY=your_passkey
MPESA_BASE_URL=https://api.safaricom.co.ke
MPESA_CALLBACK_URL=https://yourdomain.com/api/payments/mpesa-callback

# M-Pesa Sandbox Configuration (Development)
MPESA_SANDBOX_CONSUMER_KEY=your_sandbox_consumer_key
MPESA_SANDBOX_CONSUMER_SECRET=your_sandbox_consumer_secret
MPESA_SANDBOX_SHORTCODE=174379
MPESA_SANDBOX_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_SANDBOX_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_SANDBOX_CALLBACK_URL=http://localhost:3000/api/payments/mpesa-callback

# Server Configuration
PORT=3000
JWT_SECRET=your_jwt_secret_key

# SMS Configuration (Africa's Talking)
# Set SMS_ENABLED=true to send real SMS, false for mock/testing
SMS_ENABLED=false
AFRICASTALKING_API_KEY=your_africastalking_api_key
AFRICASTALKING_USERNAME=your_africastalking_username
SMS_SENDER_ID=BENSTRANS
